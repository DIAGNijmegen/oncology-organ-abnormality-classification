from util.snakemake_helpers import VALID_ORGANS


def get_scans_for_split(split):
    """Get all scan IDs for a split, independent of organ."""
    if split == "training":
        scans = train_scan_ids_split
    elif split == "validation":
        scans = val_scan_ids_split
    else:  # test
        scans = test_scan_ids
    return sorted(scans)


def get_batch_ids_for_model_split_organ(model_name, split, organ_name):
    """Get all batch IDs for a given model/split/organ combination."""
    scans = get_scans_for_split(split)
    scan_batches = create_batches(scans, BATCH_SIZE)
    batch_ids = []
    for batch_idx in range(len(scan_batches)):
        batch_id = get_batch_id(batch_idx, len(scan_batches))
        batch_ids.append(batch_id)
    return batch_ids


def get_scans_for_batch(model_name, split, batch_id):
    """Get scan IDs for a specific batch."""
    scans = get_scans_for_split(split)
    scan_batches = create_batches(scans, BATCH_SIZE)
    batch_idx = int(batch_id.split("_")[1])
    return scan_batches[batch_idx]


def get_scan_paths_for_batch(wildcards):
    """Get scan paths for a batch."""
    batch_scans = get_scans_for_batch(wildcards.model_name, wildcards.split, wildcards.batch_id)
    
    scan_paths = []
    for scan_id in batch_scans:
        if wildcards.split != "test":
            scan_path = DATASET_ROOT + f"/LEAVS/imagesTr/{scan_id}.nii.gz"
        else:
            scan_path = DATASET_ROOT + f"/LEAVS/imagesTs/{scan_id}.nii.gz"
        scan_paths.append(scan_path)
    return scan_paths


def get_seg_paths_for_batch(wildcards):
    """Get segmentation paths for a batch."""
    batch_scans = get_scans_for_batch(wildcards.model_name, wildcards.split, wildcards.batch_id)
    
    seg_paths = []
    for scan_id in batch_scans:
        seg_path = DATASET_ROOT + f"/LEAVS/AMOS-MM-TotalSegmentator/{scan_id}_segmentation.nii.gz"
        seg_paths.append(seg_path)
    return seg_paths


def get_output_paths_for_batch_key(model_name, split, organ_name, batch_id):
    """Get all output paths for a batch - returns list."""
    batch_scans = get_scans_for_batch(model_name, split, batch_id)
    
    output_paths = []
    for organ in VALID_ORGANS:
        for scan_id in batch_scans:
            output_path = OUTPUT_ROOT + f"/{model_name}/{organ}/{split}/features/raw/{scan_id}.npz"
            output_paths.append(output_path)
    return output_paths


def get_output_paths_dict_for_batch(wildcards):
    """Get output paths dictionary organized by organ."""
    batch_scans = get_scans_for_batch(wildcards.model_name, wildcards.split, wildcards.batch_id)
    
    output_paths = {}
    for organ_name in VALID_ORGANS:
        organ_outputs = []
        for scan_id in batch_scans:
            output_path = OUTPUT_ROOT + f"/{wildcards.model_name}/{organ_name}/{wildcards.split}/features/raw/{scan_id}.npz"
            organ_outputs.append(output_path)
        output_paths[organ_name] = organ_outputs
    return output_paths


def format_output_paths_arg(output_paths_dict):
    """Format output paths dictionary into command-line argument format."""
    parts = []
    for organ_name, paths in output_paths_dict.items():
        for path in paths:
            parts.append(f"{organ_name}:{path}")
    return ",".join(parts)


def join_scan_paths(wildcards):
    """Join scan paths with newlines."""
    return "\n".join(get_scan_paths_for_batch(wildcards))


def join_seg_paths(wildcards):
    """Join segmentation paths with newlines."""
    return "\n".join(get_seg_paths_for_batch(wildcards))


def output_paths_to_lines(output_paths_dict):
    """Format output paths dictionary into newline separated organ:path lines."""
    parts = []
    for organ_name, paths in output_paths_dict.items():
        for path in paths:
            parts.append(f"{organ_name}:{path}")
    return "\n".join(parts)


def get_model_resources(wildcards):
    """Get resources based on model name."""
    model_resources = {
        "ctfm": {
            "image": "jtagscherer/evalblocks-ctfm:0.0.1",
            "group": "featuremodels_ctfm"
        },
        "curia": {
            "image": "jtagscherer/evalblocks-huggingface:0.0.1",
            "group": "featuremodels_curia"
        },
        "umedpt": {
            "image": "jtagscherer/evalblocks-umedpt:0.0.1",
            "group": "featuremodels_umedpt"
        },
        "spectre": {
            "image": "jtagscherer/evalblocks-spectre:0.0.1",
            "group": "featuremodels_spectre"
        },
        "tapct": {
            "image": "jtagscherer/evalblocks-huggingface:0.0.1",
            "group": "featuremodels_tapct"
        }
    }
    return model_resources.get(wildcards.model_name, model_resources["ctfm"])


def get_model_script_command(wildcards):
    """Get the Python module command for the model."""
    model_scripts = {
        "ctfm": "featuremodels.scripts.ctfm",
        "curia": "featuremodels.scripts.curia",
        "umedpt": "featuremodels.scripts.umedpt",
        "spectre": "featuremodels.scripts.spectre",
        "tapct": "featuremodels.scripts.tapct"
    }
    return model_scripts.get(wildcards.model_name, "featuremodels.scripts.ctfm")


def get_hf_home_env(wildcards):
    """Get HF_HOME environment variable for models that need it."""
    if wildcards.model_name in ["curia", "tapct"]:
        return f"export HF_HOME={HF_HOME} && "
    return ""


# Generate all batch combinations and their outputs
model_names = ["ctfm", "curia", "umedpt", "spectre", "tapct"]
splits = ["training", "validation", "test"]

# Pre-generate outputs for each batch combination
batch_outputs = {}
for model_name in model_names:
    for split in splits:
        for organ_name in VALID_ORGANS:
            batch_ids = get_batch_ids_for_model_split_organ(model_name, split, organ_name)
            for batch_id in batch_ids:
                key = (model_name, split, organ_name, batch_id)
                batch_outputs[key] = get_output_paths_for_batch_key(model_name, split, organ_name, batch_id)


rule compute_features:
    input:
        scan_paths = get_scan_paths_for_batch,
        seg_paths = get_seg_paths_for_batch
    output:
        progress_files = expand(
            OUTPUT_ROOT + "/{{model_name}}/progress/{{split}}/{done_organ}/{{batch_id}}_features.done",
            done_organ=VALID_ORGANS
        )
    resources:
        image = lambda wildcards: get_model_resources(wildcards)["image"],
        qos = "low",
        cpus = 16,
        gpus = 1,
        mem_mb = 32000,
        time = "1-00:00:00"
    params:
        output_paths_dict = get_output_paths_dict_for_batch,
        script_module = get_model_script_command,
        hf_home_env = get_hf_home_env,
        scan_paths_str = join_scan_paths,
        seg_paths_str = join_seg_paths,
        output_paths_str = lambda wildcards: output_paths_to_lines(get_output_paths_dict_for_batch(wildcards))
    shell:
        """
        scan_paths_file=$(mktemp /tmp/scan_paths.XXXXXX)
        seg_paths_file=$(mktemp /tmp/seg_paths.XXXXXX)
        output_paths_file=$(mktemp /tmp/output_paths.XXXXXX)
        cat > "$scan_paths_file" << 'EOF_SCAN_PATHS'
{params.scan_paths_str}
EOF_SCAN_PATHS
        cat > "$seg_paths_file" << 'EOF_SEG_PATHS'
{params.seg_paths_str}
EOF_SEG_PATHS
        cat > "$output_paths_file" << 'EOF_OUTPUT_PATHS'
{params.output_paths_str}
EOF_OUTPUT_PATHS
        ./run_from_repository.sh "{REPOSITORY_ROOT}" \
            "{params.hf_home_env}cd {REPOSITORY_ROOT} && \
            /usr/local/bin/python3 -m {params.script_module} \
                --scan-paths-file $scan_paths_file \
                --seg-paths-file $seg_paths_file \
                --output-paths-file $output_paths_file && \
            rm -f $scan_paths_file $seg_paths_file $output_paths_file && \
            for done_file in {output.progress_files}; do \
                mkdir -p $(dirname $done_file) && \
                touch $done_file; \
            done"
            """
