from util.snakemake_helpers import setup_leavs_dataset

# Set up LEAVS dataset information
leavs_data = setup_leavs_dataset(DATASET_ROOT, val_ratio=0.2, seed=42, filter_valid_labels=True)
train_annotations = leavs_data["train_annotations"]
test_annotations = leavs_data["test_annotations"]
train_scan_ids_split = leavs_data["train_scan_ids_split"]
val_scan_ids_split = leavs_data["val_scan_ids_split"]
test_scan_ids = leavs_data["test_scan_ids"]
valid_organs = leavs_data["valid_organs"]
get_scans_for_split_and_organ = leavs_data["get_scans_for_split_and_organ"]


rule compute_features_ctfm:
    input:
        scan_path = lambda wildcards: DATASET_ROOT + f"/LEAVS/imagesTr/{wildcards.scan_id}.nii.gz" if wildcards.split != "test" else DATASET_ROOT + f"/LEAVS/imagesTs/{wildcards.scan_id}.nii.gz",
        seg_path = DATASET_ROOT + "/LEAVS/AMOS-MM-TotalSegmentator/{scan_id}_segmentation.nii.gz"
    output:
        output_path = OUTPUT_ROOT + "/ctfm/{organ_name}/{split}/features/raw/{scan_id}.npz"
    resources:
        image = "jtagscherer/evalblocks-ctfm:0.0.1",
        qos="low",
        cpus=16,
        gpus=1,
        mem_mb=32000,
        time="1-00:00:00"
    shell:
        """
        ./run_from_repository.sh "{REPOSITORY_ROOT}" \
            "cd {REPOSITORY_ROOT} && \
            /usr/local/bin/python3 -m featuremodels.scripts.ctfm \
                --scan-path {input.scan_path} \
                --seg-path {input.seg_path} \
                --organ-name {wildcards.organ_name} \
                --output-path {output.output_path}"
        """

rule compute_features_curia:
    input:
        scan_path = lambda wildcards: DATASET_ROOT + f"/LEAVS/imagesTr/{wildcards.scan_id}.nii.gz" if wildcards.split != "test" else DATASET_ROOT + f"/LEAVS/imagesTs/{wildcards.scan_id}.nii.gz",
        seg_path = DATASET_ROOT + "/LEAVS/AMOS-MM-TotalSegmentator/{scan_id}_segmentation.nii.gz"
    output:
        output_path = OUTPUT_ROOT + "/curia/{organ_name}/{split}/features/raw/{scan_id}.npz"
    resources:
        image = "jtagscherer/evalblocks-huggingface:0.0.1",
        qos="low",
        cpus=16,
        gpus=1,
        mem_mb=32000,
        time="1-00:00:00"
    shell:
        """
        ./run_from_repository.sh "{REPOSITORY_ROOT}" \
            "export HF_HOME={HF_HOME} && \
            cd {REPOSITORY_ROOT} && \
            /usr/local/bin/python3 -m featuremodels.scripts.curia \
                --scan-path {input.scan_path} \
                --seg-path {input.seg_path} \
                --organ-name {wildcards.organ_name} \
                --output-path {output.output_path}"
        """

