rule aggregate_mean:
    input:
        input_features = OUTPUT_ROOT + "/{model_name}/{organ_name}/{split}/features/raw/{scan_id}.npz"
    output:
        output_features = OUTPUT_ROOT + "/{model_name}/{organ_name}/{split}/features/aggregated/mean/{scan_id}.npz"
    group: "aggregation"
    resources:
        image = "jtagscherer/evalblocks-core:0.0.1",
        qos="idle",
        time="1-00:00:00"
    shell:
        """
        ./run_from_repository.sh "{REPOSITORY_ROOT}" \
            "cd {REPOSITORY_ROOT} && \
            /usr/local/bin/python3 -m aggregation.scripts.mean \
                --input-features {input.input_features} \
                --output-features {output.output_features}"
        """

