from util.snakemake_helpers import setup_leavs_dataset

# Set up LEAVS dataset information
leavs_data = setup_leavs_dataset(DATASET_ROOT, val_ratio=0.2, seed=42, filter_valid_labels=True)
get_scans_for_split_and_organ = leavs_data["get_scans_for_split_and_organ"]


def get_batch_ids_for_model_split_organ(model_name, split, organ_name):
    """Get all batch IDs for a given model/split/organ combination - harmonized with feature models and aggregation."""
    scans = get_scans_for_split_and_organ(split, organ_name)
    scan_batches = create_batches(scans, BATCH_SIZE)
    batch_ids = []
    for batch_idx in range(len(scan_batches)):
        batch_id = get_batch_id(batch_idx, len(scan_batches))
        batch_ids.append(batch_id)
    return batch_ids


def get_aggregation_progress_files(wildcards):
    """Get all aggregation progress files for a given model/organ/aggregation_method combination."""
    progress_files = []
    for split in ["training", "validation", "test"]:
        batch_ids = get_batch_ids_for_model_split_organ(wildcards.model_name, split, wildcards.organ_name)
        for batch_id in batch_ids:
            if wildcards.aggregation_method == "mean":
                progress_file = OUTPUT_ROOT + f"/{wildcards.model_name}/progress/{split}/{wildcards.organ_name}/{batch_id}_mean.done"
            else:  # max
                progress_file = OUTPUT_ROOT + f"/{wildcards.model_name}/progress/{split}/{wildcards.organ_name}/{batch_id}_max.done"
            progress_files.append(progress_file)
    return progress_files


rule evaluate_knn:
    input:
        aggregation_progress_files = get_aggregation_progress_files
    output:
        output_metrics = OUTPUT_ROOT + "/{model_name}/{organ_name}/metrics/aggregated/{aggregation_method}/knn.json"
    params:
        annotations_train_csv = DATASET_ROOT + "/LEAVS/amos_train_annotations.csv",
        annotations_test_csv = DATASET_ROOT + "/LEAVS/amos_test_annotations.csv"
    resources:
        image="jtagscherer/evalblocks-core:0.0.1",
        qos="idle",
        cpus=8,
        gpus=0,
        mem_mb=16000,
        time="1-00:00:00"
    shell:
        """
        ./run_from_repository.sh "{REPOSITORY_ROOT}" \
            "cd {REPOSITORY_ROOT} && \
            /usr/local/bin/python3 -m evaluation.scripts.knn \
                --output-root {OUTPUT_ROOT} \
                --model-name {wildcards.model_name} \
                --aggregation-method {wildcards.aggregation_method} \
                --annotations-train-csv {params.annotations_train_csv} \
                --annotations-test-csv {params.annotations_test_csv} \
                --organ-name {wildcards.organ_name}"
        """

rule evaluate_linear_probing:
    input:
        aggregation_progress_files = get_aggregation_progress_files
    output:
        output_metrics = OUTPUT_ROOT + "/{model_name}/{organ_name}/metrics/aggregated/{aggregation_method}/linear.json",
        output_checkpoint = directory(OUTPUT_ROOT + "/{model_name}/{organ_name}/checkpoints/aggregated/{aggregation_method}/")
    params:
        annotations_train_csv = DATASET_ROOT + "/LEAVS/amos_train_annotations.csv",
        annotations_test_csv = DATASET_ROOT + "/LEAVS/amos_test_annotations.csv"
    resources:
        image = "jtagscherer/evalblocks-core:0.0.1",
        qos="idle",
        cpus=8,
        gpus=1,
        mem_mb=24000,
        time="1-00:00:00"
    shell:
        """
        ./run_from_repository.sh "{REPOSITORY_ROOT}" \
            "cd {REPOSITORY_ROOT} && \
            /usr/local/bin/python3 -m evaluation.scripts.linearprobing \
                --output-root {OUTPUT_ROOT} \
                --model-name {wildcards.model_name} \
                --aggregation-method {wildcards.aggregation_method} \
                --annotations-train-csv {params.annotations_train_csv} \
                --annotations-test-csv {params.annotations_test_csv} \
                --organ-name {wildcards.organ_name} \
                --seed 0"
        """
